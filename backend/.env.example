# Copy to .env and fill in. NEVER put real secrets in this file (it is committed).

# ---- Runtime ----
NODE_ENV=development
PORT=8080

# Public URLs
APP_URL=http://localhost:5173      # the web app; share links look like {APP_URL}/s/{token}#{key}

# Cookies (refresh token)
COOKIE_SECURE=false                 # set true in production (HTTPS)

# ---- Datastores ----
MONGODB_URI=mongodb://localhost:27017/pwpusher   # or a MongoDB Atlas SRV URI
REDIS_URL=redis://localhost:6379                 # or an Upstash rediss:// URL

# ---- Secrets ----  (generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=replace-with-a-long-random-string
COOKIE_SECRET=replace-with-a-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=15

# At-rest encryption key (generate with: openssl rand -base64 32  -> 32 bytes)
# Required in production. In dev a fixed key is used if left empty.
MASTER_ENCRYPTION_KEY=

# ---- Google OAuth (https://console.cloud.google.com) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Email (https://resend.com) — if empty in dev, codes print to the console ----
RESEND_API_KEY=
EMAIL_FROM=PW Pusher <onboarding@resend.dev>

# ---- Rate limiting ----
RATE_LIMIT_MAX=120
